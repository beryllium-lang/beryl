#!/bin/bash
set -e

INSTALL_DIR="$HOME/.local/bin"
VENV_DIR="$HOME/.local/share/minoil-venv"
PYTHON_BIN="python3"

MINOIL_SCRIPT="minoil.py"
MINOIL_CMD="minoil"
MINOIL_ALIAS="mineraloil"

BERYL_SCRIPT="beryl"
BERYL_CMD="beryl"

echo "Installing MineralOil + Beryllium..."

mkdir -p "$INSTALL_DIR"
mkdir -p "$(dirname "$VENV_DIR")"

# -----------------------
# Create venv if missing
# -----------------------
if [ ! -d "$VENV_DIR" ]; then
    echo "Creating venv for minoil..."
    "$PYTHON_BIN" -m venv "$VENV_DIR"
fi

# -----------------------
# Install dependencies
# -----------------------
echo "Ensuring dependencies..."
"$VENV_DIR/bin/pip" install --upgrade pip >/dev/null
"$VENV_DIR/bin/pip" install requests >/dev/null

# -----------------------
# Install minoil
# -----------------------
cp "$MINOIL_SCRIPT" "$INSTALL_DIR/$MINOIL_CMD"
chmod +x "$INSTALL_DIR/$MINOIL_CMD"
ln -sf "$INSTALL_DIR/$MINOIL_CMD" "$INSTALL_DIR/$MINOIL_ALIAS"

# -----------------------
# Install beryl
# -----------------------
# -----------------------
# Install beryl
# -----------------------
if [ "$(realpath "$BERYL_SCRIPT")" = "$(realpath "$INSTALL_DIR/$BERYL_CMD" 2>/dev/null)" ]; then
    echo "Beryllium is already up to date."
else
    if [ -f "$INSTALL_DIR/$BERYL_CMD" ] && cmp -s "$BERYL_SCRIPT" "$INSTALL_DIR/$BERYL_CMD"; then
        echo "Beryllium is already up to date."
    else
        cp "$BERYL_SCRIPT" "$INSTALL_DIR/$BERYL_CMD"
        chmod +x "$INSTALL_DIR/$BERYL_CMD"
        echo "Beryllium updated!"
    fi
fi

# -----------------------
# PATH handling
# -----------------------
if ! echo "$PATH" | grep -q "$INSTALL_DIR"; then
    echo "export PATH=\"$INSTALL_DIR:\$PATH\"" >> "$HOME/.bashrc"
    echo "Added $INSTALL_DIR to PATH. Run: source ~/.bashrc"
fi

echo
echo "MineralOil updated using venv: $VENV_DIR"
echo "Run: minoil | mineraloil | beryl"
echo "To use MineralOil and Beryllium commands."